<mvc:View
    controllerName="service.controller.CreateProduct"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:f="sap.ui.layout.form"
    xmlns:core="sap.ui.core"
>
    <Page
        title="{i18n>creatingProduct}"
        showNavButton="true"
        navButtonPress="onCancel"
    >
        <content>
            <f:SimpleForm
                editable="true"
                layout="ResponsiveGridLayout"
                title="{i18n>newProduct}"
                labelSpanXL="4"
                labelSpanL="4"
                labelSpanM="4"
                labelSpanS="12"
                adjustLabelSpan="false"
                emptySpanXL="0"
                emptySpanL="0"
                emptySpanM="0"
                emptySpanS="0"
                columnsXL="2"
                columnsL="2"
                columnsM="1"
                singleContainerFullSize="false"
            >
                <f:content>
                    <core:Title text="{i18n>mainInfo}" />

                    <Label
                        text="{i18n>name}"
                        required="true"
                    />
                    <Input
                        value="{appModel>/newProduct/Name}"
                        placeholder="{i18n>nameOfTheProduct}"
                    />

                    <Label
                        text="{i18n>shop}"
                        required="true"
                    />
                    <Select
                        selectedKey="{appModel>/newProduct/Store_ID}"
                        items="{path: '/Stores', sorter: {path: 'Name'}}"
                        forceSelection="false"
                    >
                        <core:Item
                            key="{ID}"
                            text="{Name} "
                        />
                    </Select>

                    <Label
                        text="{i18n>status}"
                        required="true"
                    />
                    <Select selectedKey="{appModel>/newProduct/Status}">
                        <core:Item
                            key="OK"
                            text="{i18n>accepted}"
                        />
                        <core:Item
                            key="OUT_OF_STOCK"
                            text="{i18n>outOfStock}"
                        />
                        <core:Item
                            key="STORAGE"
                            text="{i18n>warning}"
                        />
                    </Select>
                    <Label
                        text="{i18n>category}"
                        required="true"
                    />
                    <Select
                        items="{appModel>/Categories}"
                        selectedKey="{appModel>/newProduct/Category}"
                    >
                        <core:Item
                            key="{appModel>key}"
                            text="{appModel>text}"
                        />
                    </Select>

                    <core:Title text="{i18n>priceAndRating}" />

                    <Label text="{i18n>price}" />
                    <Input
                        value="{
      path: 'appModel>/newProduct/Price_amount',
                        type: 'sap.ui.model.type.Float',
                        formatOptions: {
                            minFractionDigits: 2,
                            maxFractionDigits: 2
                        }
                    }"
                        placeholder="0.00"
                    />

                    <Label text="{i18n>currency}" />
                    <Select selectedKey="{appModel>/newProduct/Price_currency}">
                        <core:Item
                            key="USD"
                            text="USD"
                        />
                        <core:Item
                            key="EUR"
                            text="EUR"
                        />
                    </Select>

                    <Label text="{i18n>rating}" />
                    <RatingIndicator
                        value="{appModel>/newProduct/Rating}"
                        maxValue="5"
                    />

                    <core:Title text="{i18n>details}" />
                    <Label text="{i18n>size}" />
                    <Input
                        value="{path : 'appModel>/newProduct/Size', type: 'sap.ui.model.type.String'}"
                        placeholder="{i18n>size}"
                    />

                    <Label text="{i18n>weight}" />
                    <Input
                        value="{path: 'appModel>/newProduct/Weight', type: 'sap.ui.model.type.Integer' }"
                        placeholder="{i18n>weight} {i18n>g}"
                    />
                    <Label text="{i18n>materials}" />
                    <Input
                        value="{appModel>/newProduct/Materials}"
                        placeholder="{i18n>materials}"
                    />

                    <Label text="{i18n>madeIn}" />
                    <Input
                        value="{appModel>/newProduct/MadeIn}"
                        placeholder="{i18n>country}"
                    />

                    <Label text="{i18n>prodCompany}" />
                    <Input
                        value="{appModel>/newProduct/ProductionCompanyName}"
                    />

                    <Label text="{i18n>suppliersInfo}" />
                    <Input value="{appModel>/newProduct/SupplierInfo}" />

                    <Label text="{i18n>specs}" />
                    <TextArea
                        value="{appModel>/newProduct/Specs}"
                        rows="3"
                    />

                    <Label text="{i18n>photoPlaceholder}" />
                    <Input
                        value="{appModel>/newProduct/Photo}"
                        placeholder="https://..."
                    />
                </f:content>
            </f:SimpleForm>
        </content>

        <footer>
            <OverflowToolbar>
                <ToolbarSpacer />
                <Button
                    text="{i18n>save}"
                    type="Emphasized"
                    press="onSave"
                />
                <Button
                    text="{i18n>discard}"
                    type="Transparent"
                    press="onCancel"
                />
            </OverflowToolbar>
        </footer>
    </Page>
</mvc:View>
