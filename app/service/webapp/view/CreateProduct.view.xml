<mvc:View
    controllerName="service.controller.CreateProduct"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:f="sap.ui.layout.form"
    xmlns:core="sap.ui.core"
>
    <Page
        title="Creating product"
        showNavButton="true"
        navButtonPress="onCancel"
    >
        <content>
            <f:SimpleForm
                editable="true"
                layout="ResponsiveGridLayout"
                title="New Product"
                labelSpanXL="4"
                labelSpanL="4"
                labelSpanM="4"
                labelSpanS="12"
                adjustLabelSpan="false"
                emptySpanXL="0"
                emptySpanL="0"
                emptySpanM="0"
                emptySpanS="0"
                columnsXL="2"
                columnsL="2"
                columnsM="1"
                singleContainerFullSize="false"
            >
                <f:content>
                    <core:Title text="Main info" />

                    <Label
                        text="Name"
                        required="true"
                    />
                    <Input
                        value="{appModel>/newProduct/Name}"
                        placeholder="Name of the product"
                    />

                    <Label
                        text="Shop"
                        required="true"
                    />
                    <Select
                        selectedKey="{appModel>/newProduct/Store_ID}"
                        items="{path: '/Stores', sorter: {path: 'Name'}}"
                        forceSelection="false"
                    >
                        <core:Item
                            key="{ID}"
                            text="{Name} "
                        />
                    </Select>

                    <Label text="Status" />
                    <Select selectedKey="{appModel>/newProduct/Status}">
                        <core:Item
                            key="OK"
                            text="Accepted"
                        />
                        <core:Item
                            key="OUT_OF_STOCK"
                            text="Out of Stock"
                        />
                        <core:Item
                            key="STORAGE"
                            text="Warning"
                        />
                    </Select>

                    <core:Title text="Price and Rating" />

                    <Label text="Price" />
                    <Input
                        value="{
      path: 'appModel>/newProduct/Price_amount',
                        type: 'sap.ui.model.type.Float',
                        formatOptions: {
                            minFractionDigits: 2,
                            maxFractionDigits: 2
                        }
                    }"
                        placeholder="0.00"
                    />

                    <Label text="Currency" />
                    <Select selectedKey="{appModel>/newProduct/Price_currency}">
                        <core:Item
                            key="USD"
                            text="USD"
                        />
                        <core:Item
                            key="EUR"
                            text="EUR"
                        />
                    </Select>

                    <Label text="Rating" />
                    <RatingIndicator
                        value="{appModel>/newProduct/Rating}"
                        maxValue="5"
                    />

                    <core:Title text="Details" />

                    <Label text="Made In" />
                    <Input
                        value="{appModel>/newProduct/MadeIn}"
                        placeholder="Country"
                    />

                    <Label text="Prod.Company" />
                    <Input
                        value="{appModel>/newProduct/ProductionCompanyName}"
                    />

                    <Label text="Suppliers Info" />
                    <Input value="{appModel>/newProduct/SupplierInfo}" />

                    <Label text="Specs" />
                    <TextArea
                        value="{appModel>/newProduct/Specs}"
                        rows="3"
                        placeholder=""
                    />

                    <Label text="URL on photo" />
                    <Input
                        value="{appModel>/newProduct/Photo}"
                        placeholder="https://..."
                    />
                </f:content>
            </f:SimpleForm>
        </content>

        <footer>
            <OverflowToolbar>
                <ToolbarSpacer />
                <Button
                    text="Save"
                    type="Emphasized"
                    press="onSave"
                />
                <Button
                    text="Discard"
                    type="Transparent"
                    press="onCancel"
                />
            </OverflowToolbar>
        </footer>
    </Page>
</mvc:View>
