<mvc:View
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    controllerName="service.controller.Cart"
    height="100%"
>
    <Page
        title="{i18n>cart}"
        showFooter="true"
        showNavButton="true"
        navButtonPress="onCloseCart"
    >
        <content>
            <List
                items="{appModel>/Cart}"
                headerText="Products"
                growing="true"
                growingThreshold="6"
                growingScrollToLoad="false"
                mode="Delete"
                delete="onPressDelete"
            >
                <items>
                    <CustomListItem type="Active">
                        <HBox
                            justifyContent="SpaceBetween"
                            class="sapUiSmallMargin"
                            alignItems="Center"
                        >
                            <VBox>
                                <Title
                                    text="{appModel>Name} x{appModel>Quantity}"
                                    level="H5"
                                />
                                <Text
                                    text="{i18n>store}: {appModel>Store/Name}"
                                    class="sapUiTinyMarginBottom"
                                />
                                <ObjectStatus
                                    text="{
                                        path: 'appModel>Status',
                                        formatter: '.formatter.statusText'
                                    }"
                                    state="{
                                        path: 'appModel>Status',
                                        formatter: '.formatter.statusState'
                                    }"
                                    inverted="true"
                                />
                                <RatingIndicator
                                    value="{appModel>Rating}"
                                    maxValue="5"
                                    editable="false"
                                />
                            </VBox>
                            <VBox alignItems="End">
                                <ObjectNumber
                                    number="{
                                        parts: [{
                                            path: 'appModel>Price_amount'
                                        }, {
                                            value: 'USD'
                                        }],
                                        type: 'sap.ui.model.type.Currency',
                                        formatOptions: {
                                            showMeasure: false
                                        }
                                    }"
                                    unit="USD"
                                    class="sapMObjectNumberMedium"
                                    state="None"
                                />
                            </VBox>
                        </HBox>
                    </CustomListItem>
                </items>
            </List>
        </content>
        <footer>
            <OverflowToolbar>
                <ObjectNumber
                    class="sapMObjectNumberLarge"
                    number="{
                        parts: [{
                            path: 'appModel>/TotalPrice'
                        }, {
                            value: 'USD'
                        }],
                        type: 'sap.ui.model.type.Currency',
                        formatOptions: {
                            showMeasure: false
                        }
                    }"
                    unit="USD"
                />
                <ToolbarSpacer />
                <Button
                    type="Accept"
                    text="{i18n>createOrder}"
                    press="onCreateOrder"
                    visible="{= ${appModel>/Cart}.length > 0 }"
                />
                <Button
                    type="Reject"
                    text="{i18n>cleanCart}"
                    press="onCleanCart"
                    visible="{= ${appModel>/Cart}.length > 0 }"
                />
            </OverflowToolbar>
        </footer>
    </Page>
</mvc:View>
