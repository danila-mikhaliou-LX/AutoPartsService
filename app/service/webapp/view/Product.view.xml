<mvc:View
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.uxap"
    xmlns:m="sap.m"
    xmlns:f="sap.ui.layout.form"
    controllerName="service.controller.Product"
    height="100%"
>
    <ObjectPageLayout upperCaseAnchorBar="false">
        <headerTitle>
            <ObjectPageHeader
                objectTitle="{Name}"
                objectSubtitle="{Specs}"
            >
                <actions>
                    <m:Button
                        text="{i18n>back}"
                        press="onPressBack"
                    />
                    <m:Button
                        text="{i18n>addToCart}"
                        press="onPressAddToCart"
                    />
                    <m:Button
                        text="{i18n>delete}"
                        press="onPressDelete"
                    />
                </actions>
            </ObjectPageHeader>
        </headerTitle>
        <headerContent>
            <m:VBox>
                <m:Avatar
                    src="{Photo}"
                    fallbackIcon="sap-icon://product"
                    displaySize="XL"
                    displayShape="Square"
                />

                <m:ObjectStatus
                    title="{i18n>supplierInfo}"
                    text="{SupplierInfo}"
                />
                <m:ObjectStatus
                    title="{i18n>category}"
                    text="{path: 'Category', formatter: '.formatter.categoryText'}"
                />

                <m:ObjectStatus
                    title="{i18n>status}"
                    text="{path: 'Status', formatter: '.formatter.statusText'}"
                    state="{path: 'Status', formatter: '.formatter.statusState'}"
                    inverted="true"
                />
                <m:ObjectStatus
                    title="{i18n>weight}"
                    text="{Weight} {i18n>g}"
                />
                <m:ObjectStatus
                    title="{i18n>size}"
                    text="{Size} {i18n>sm}"
                />
                <m:ObjectStatus
                    title="{i18n>materials}"
                    text="{ path: 'Materials',
                    formatter: '.formatter.materialText'}"
                />

                <m:RatingIndicator
                    editable="false"
                    maxValue="5"
                    value="{Rating}"
                />
                <m:ObjectNumber
                    class="sapMObjectNumberLarge"
                    number="{
        parts:[
            {path:'Price_amount'},
            {value: 'Price_currency'} ],
        type: 'sap.ui.model.type.Currency',
        formatOptions: {showMeasure: false}
    }"
                    unit="{Price_currency}"
                />
            </m:VBox>
        </headerContent>
        <sections>
            <ObjectPageSection
                titleUppercase="false"
                title="{i18n>storeInfo}"
            >
                <subSections>
                    <ObjectPageSubSection>
                        <m:VBox class="sapUiSmallMargin">
                            <f:SimpleForm
                                editable="false"
                                title="{i18n>storeInfo}"
                            >
                                <f:content>
                                    <m:Label text="{i18n>name}" />
                                    <m:Text text="{Store/Name}" />
                                    <m:Label text="{i18n>email}" />
                                    <m:Text text="{Store/Email}" />
                                    <m:Label text="{i18n>phoneNumber}" />
                                    <m:Text text="{Store/PhoneNumber}" />
                                    <m:Label text="{i18n>address}" />
                                    <m:Text text="{Store/Address}" />
                                    <m:Label text="{i18n>established}" />
                                    <m:Text text="{Store/Established}" />
                                    <m:Label text="{i18n>floorArea}" />
                                    <m:Text
                                        text="{Store/FloorArea} {i18n>sqm}"
                                    />
                                </f:content>
                            </f:SimpleForm>
                        </m:VBox>
                    </ObjectPageSubSection>
                </subSections>
            </ObjectPageSection>
            <ObjectPageSection
                titleUppercase="false"
                title="{i18n>feedback}"
            >
                <subSections>
                    <ObjectPageSubSection>
                        <m:VBox>
                            <m:FeedInput
                                post="onPost"
                                class="sapUiSmallMarginTopBottom"
                            />
                            <m:List
                                showSeparators="Inner"
                                items="{Comment}"
                            >
                                <m:FeedListItem
                                    sender="{Author}"
                                    timestamp="{Posted}"
                                    text="{Message}"
                                />
                            </m:List>
                        </m:VBox>
                    </ObjectPageSubSection>
                </subSections>
            </ObjectPageSection>
        </sections>
    </ObjectPageLayout>
</mvc:View>
