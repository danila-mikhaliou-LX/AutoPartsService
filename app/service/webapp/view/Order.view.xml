<mvc:View
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    controllerName="service.controller.Order"
    height="100%"
>
    <Page
        title="{i18n>orderDetails}"
        showNavButton="{= ${appModel>/layout} !== 'OneColumn' }"
        navButtonPress="onNavBack"
    >
        <content>
            <ObjectHeader
                title="{i18n>order} #{= ${ID}.substring(0,8) }"
                number="{
                    path: 'Price_amount',
                    type: 'sap.ui.model.type.Float',
                    formatOptions: {
                        minFractionDigits: 2,
                        maxFractionDigits: 2
                    }
                }"
                numberUnit="{Price_currency}"
                class="sapUiResponsiveMargin"
            >
                <attributes>
                    <ObjectAttribute
                        title="{i18n>createdDate}"
                        text="{
                            path: 'createdAt',
                            formatOptions: {
                                style: 'medium'
                            }
                        }"
                    />
                    <ObjectAttribute
                        title="{i18n>estimatedDelivery}"
                        text="{
                            path: 'createdAt',
                            formatter: '.formatter.deliveryDate'
                        }"
                    />
                </attributes>
            </ObjectHeader>
            <Table
                id="orderItemsTable"
                items="{
                    path: 'Items',
                    parameters: {
                        $expand: 'Product'
                    }
                }"
                backgroundDesign="Transparent"
            >
                <headerToolbar>
                    <OverflowToolbar>
                        <Title
                            text="{i18n>products} ({Items/$count})"
                            level="H2"
                        />
                    </OverflowToolbar>
                </headerToolbar>
                <columns>
                    <Column>
                        <Text text="{i18n>products}" />
                    </Column>
                    <Column
                        hAlign="Center"
                        demandPopin="true"
                        minScreenWidth="Tablet"
                        popinDisplay="Inline"
                    >
                        <Text text="{i18n>quantity}" />
                    </Column>
                    <Column
                        hAlign="End"
                        demandPopin="true"
                        minScreenWidth="Desktop"
                        popinDisplay="Inline"
                    >
                        <Text text="{i18n>pricePerUnit}" />
                    </Column>
                    <Column
                        hAlign="End"
                        demandPopin="true"
                        minScreenWidth="Tablet"
                        popinDisplay="WithoutHeader"
                    >
                        <Text text="{i18n>totalPrice}" />
                    </Column>
                </columns>
                <items>
                    <ColumnListItem type="Inactive">
                        <cells>
                            <ObjectIdentifier title="{Product/Name}" />
                            <Text text="{Quantity}" />
                            <ObjectNumber
                                number="{
                                    path: 'Product/Price_amount',
                                    type: 'sap.ui.model.type.Float',
                                    formatOptions: {
                                        minFractionDigits: 2,
                                        maxFractionDigits: 2
                                    }
                                }"
                                unit="{Product/Price_currency}"
                            />
                            <ObjectNumber
                                number="{
                                    parts: [{
                                        path: 'Product/Price_amount'
                                    }, {
                                        path: 'Quantity'
                                    }],
                                    formatter: '.formatter.calculateTotal'
                                }"
                                unit="{Product/Price_currency}"
                            />
                        </cells>
                    </ColumnListItem>
                </items>
            </Table>
        </content>
    </Page>
</mvc:View>
