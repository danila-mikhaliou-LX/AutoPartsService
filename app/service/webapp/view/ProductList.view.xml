<mvc:View
    controllerName="service.controller.ProductList"
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:f="sap.f"
    xmlns:mvc="sap.ui.core.mvc"
>
    <f:DynamicPage toggleHeaderOnTitleClick="false">
        <f:title>
            <f:DynamicPageTitle>
                <f:heading>
                    <Title text="{i18n>products} ({/Products/$count})" />
                </f:heading>
                <f:actions>
                    <Button
                        text="{i18n>orders} "
                        press="onPressOrders"
                    />

                    <Button
                        text="{i18n>cart} ({= ${appModel>/CartWeight}})"
                        press="onPressCart"
                    />
                    <Button
                        icon="sap-icon://world"
                        tooltip="RU / EN"
                        press="onToggleLanguage"
                        type="Transparent"
                    />

                    <Button
                        icon="sap-icon://palette"
                        tooltip="{i18n>toggleTheme}"
                        press="onToggleTheme"
                        type="Transparent"
                    />
                </f:actions>
            </f:DynamicPageTitle>
        </f:title>

        <f:content>
            <VBox>
                <OverflowToolbar class="sapFDynamicPageAlignContent">
                    <ToolbarSpacer />
                    <SearchField
                        id="searchFieldName"
                        search="onSearch"
                        width="15rem"
                    />
                    <HBox alignItems="Center">
                        <Label
                            text="{i18n>price}:"
                            class="sapUiTinyMarginEnd"
                        />
                        <RangeSlider
                            id="sliderPrice"
                            change="onSearch"
                            showAdvancedTooltip="true"
                            min="0"
                            max="1000"
                            width="15rem"
                        />
                    </HBox>
                    <ToolbarSeparator />

                    <HBox alignItems="Center">
                        <Label
                            text="{i18n>status}:"
                            class="sapUiTinyMarginEnd"
                        />
                        <Select
                            id="selectStatus"
                            change="onSearch"
                        >
                            <core:ListItem
                                key=""
                                text="{i18n>all}"
                            />

                            <core:ListItem
                                key="OK"
                                text="{i18n>available}"
                            />
                            <core:ListItem
                                key="STORAGE"
                                text="{i18n>storage}"
                            />
                            <core:ListItem
                                key="OUT_OF_STOCK"
                                text="{i18n>outOfStock}"
                            />
                        </Select>
                    </HBox>
                    <ToolbarSeparator />
                    <HBox alignItems="Center">
                        <Label
                            text="{i18n>category}:"
                            class="sapUiTinyMarginEnd"
                        />
                        <Select
                            id="selectCategory"
                            change="onSearch"
                            items="{appModel>/Categories}"
                        >
                            <core:Item
                                key="{appModel>key}"
                                text="{appModel>text}"
                            />
                        </Select>
                    </HBox>

                    <OverflowToolbarButton
                        icon="sap-icon://add-product"
                        text="{i18n>add}"
                        type="Transparent"
                        press="onPressAddProduct"
                    />
                </OverflowToolbar>
                <Table
                    id="productsTable"
                    items="{
        path: '/Products',
        sorter: [{
            path: 'Name',
            descending: false
        }, {
            path: 'Status',
            descending: false
        }]
    }"
                    class="sapFDynamicPageAlignContent"
                    width="auto"
                    itemPress="onProductPress"
                    mode="SingleSelectMaster"
                    growing="true"
                    growingScrollToLoad="true"
                    growingThreshold="50"
                >
                    <columns>
                        <Column width="12em">
                            <Text text="{i18n>product}" />
                        </Column>
                        <Column hAlign="End">
                            <Text text="{i18n>status}" />
                        </Column>
                        <Column hAlign="End">
                            <Text text="{i18n>price}" />
                        </Column>
                    </columns>
                    <items>
                        <ColumnListItem type="Navigation">
                            <cells>
                                <ObjectIdentifier title="{Name}" />
                                <ObjectStatus
                                    text="{
                              path: 'Status',
                              formatter: '.formatter.statusText'}"
                                    state="{
                              path: 'Status',
                              formatter: '.formatter.statusState'
                              }"
                                />
                            </cells>
                            <ObjectNumber
                                number="{
        parts:[
            {path:'Price_amount'},
            {value: 'Price_currency'} ],
        type: 'sap.ui.model.type.Currency',
        formatOptions: {showMeasure: false}
    }"
                                unit="{Price_currency}"
                            />
                        </ColumnListItem>
                    </items>
                </Table>
            </VBox>
        </f:content>
    </f:DynamicPage>
</mvc:View>
