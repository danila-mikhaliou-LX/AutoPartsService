<mvc:View
    controllerName="service.controller.ProductList"
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:f="sap.f"
    xmlns:mvc="sap.ui.core.mvc"
>
    <f:DynamicPage toggleHeaderOnTitleClick="false">
        <f:title>
            <f:DynamicPageTitle>
                <f:heading>
                    <Title text="Products ({/Products/$count})" />
                </f:heading>
                <f:actions>
                    <Button
                        text="Orders "
                        press="onPressOrders"
                    />

                    <Button
                        text="Cart ({= ${appModel>/CartWeight}})"
                        press="onPressCart"
                    />
                </f:actions>
            </f:DynamicPageTitle>
        </f:title>

        <f:content>
            <VBox fitContainer="true">
                <OverflowToolbar class="sapFDynamicPageAlignContent">
                    <ToolbarSpacer />
                    <SearchField
                        search="onSearch"
                        width="17.5rem"
                    />
                    <OverflowToolbarButton
                        icon="sap-icon://add"
                        text="Add"
                        type="Transparent"
                        press="onPressAddProduct"
                    />
                </OverflowToolbar>
                <Table
                    id="productsTable"
                    items="{
        path: '/Products',
        sorter: [{
            path: 'Name',
            descending: false
        }, {
            path: 'Status',
            descending: false
        }]
    }"
                    class="sapFDynamicPageAlignContent"
                    width="auto"
                    itemPress="onProductPress"
                    mode="SingleSelectMaster"
                >
                    <columns>
                        <Column width="12em">
                            <Text text="Product" />
                        </Column>
                        <Column hAlign="End">
                            <Text text="Status" />
                        </Column>
                        <Column hAlign="End">
                            <Text text="Price" />
                        </Column>
                    </columns>
                    <items>
                        <ColumnListItem type="Navigation">
                            <cells>
                                <ObjectIdentifier title="{Name}" />
                                <ObjectStatus
                                    text="{
                              path: 'Status',
                              formatter: '.formatter.statusText'}"
                                    state="{
                              path: 'Status',
                              formatter: '.formatter.statusState'
                              }"
                                />
                            </cells>
                            <ObjectNumber
                                number="{
        parts:[
            {path:'Price_amount'},
            {value: 'Price_currency'} ],
        type: 'sap.ui.model.type.Currency',
        formatOptions: {showMeasure: false}
    }"
                                unit="{Price_currency}"
                            />
                        </ColumnListItem>
                    </items>
                </Table>
            </VBox>
        </f:content>
    </f:DynamicPage>
</mvc:View>
